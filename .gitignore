# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
*.egg-info/
.ipynb_checkpoints/

# 대용량 원본·중간 데이터
data/raw/*
data/frames/*
!data/raw/.gitkeep
!data/frames/.gitkeep
data/external/YouCookII/features/feat_csv/
data/external/YouCookII/features/feat_dat/

# 클라우드 업로드용 임시 아카이브 (frames.tar 등) — 절대 커밋 금지
*.tar
*.tar.gz
*.zip

# 모델 체크포인트 — 가중치(.pt)는 너무 커서(개당 ~420MB) git 부적합 → Releases/외부 스토리지로 배포.
# history.json은 commit (epoch별 메트릭, 시각화·분석·재현성에 필요, 수 KB).
checkpoints/**/*.pt
!checkpoints/.gitkeep

# 실험 로그·시각화 산출물 (필요시 선택적으로 커밋)
reports/logs/*
!reports/logs/.gitkeep

# OS / 에디터
.DS_Store
Thumbs.db
.vscode/
.idea/

# 환경 변수
.env
.env.local

# 검수용 임시 xlsx (편집 후 CSV로 변환 → 커밋, xlsx는 로컬 보관)
data/processed/*.xlsx

# 인증 비밀 (YouTube 쿠키 등). 절대 커밋 금지.
secrets/
cookies.txt
*.cookies
